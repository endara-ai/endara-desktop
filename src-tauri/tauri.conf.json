{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Endara Desktop",
  "mainBinaryName": "Endara Desktop",
  "version": "0.1.4",
  "identifier": "ai.endara.desktop",
  "build": {
    "beforeDevCommand": "ENDARA_DEV_PORT=9500 bash scripts/kill-relay.sh; npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Endara Desktop",
        "width": 1024,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: asset: http://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://localhost:* http://127.0.0.1:*; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/endara-ai/endara-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg4OURGRDRCRDk2RDRGRDMKUldUVFQyM1pTLzJkaUorVndlR3dBaTltWXpjZXREYnBFRDVNK2hNS2JKYTd0Wm1kcSsySUU2L04K"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "nsis", "msi", "dmg", "deb", "appimage"],
    "externalBin": [
      "binaries/endara-relay"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" },
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": true,
        "languages": ["English", "French", "Spanish", "Japanese", "SimpChinese"]
      },
      "wix": {}
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "desktopTemplate": null
      },
      "appimage": {}
    }
  }
}
